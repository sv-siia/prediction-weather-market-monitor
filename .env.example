# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREDICTIONS=polymarket-predictions-raw
KAFKA_TOPIC_WEATHER=weather-actuals-raw
KAFKA_TOPIC_CORRELATIONS=market-weather-correlations
KAFKA_TOPIC_AGGREGATES=market-accuracy-aggregates
KAFKA_TOPIC_ALERTS=arbitrage-alerts

# Polling intervals (seconds)
POLYMARKET_POLL_INTERVAL=300
WEATHER_POLL_INTERVAL=900

# APIs
POLYMARKET_API_URL=https://clob.polymarket.com/markets
OPEN_METEO_API_URL=https://api.open-meteo.com/v1/forecast

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=prediction_market
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme

# Flink
FLINK_CHECKPOINT_DIR=/flink-checkpoints
FLINK_CHECKPOINT_INTERVAL=60000

# Development mode
USE_SYNTHETIC_DATA=false

# ── Scenario selection ───────────────────────────────────────────
# Scenario 1 — Python scripts (default, no extra dependencies):
#   docker-compose --profile python up
#
# Scenario 2 — PyFlink with event-time windowing + watermarks:
#   docker-compose --profile pyflink up

ANTHROPIC_API_KEY=your_anthropic_api_key_here
